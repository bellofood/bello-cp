{
  "functions": {
    "pages/api/**/*.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "regions": ["iad1"],
  "installCommand": "npm install --legacy-peer-deps",
  "headers": [
    {
      "source": "/assets/video/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/mp4"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Accept-Ranges",
          "value": "bytes"
        }
      ]
    }
  ]
}
